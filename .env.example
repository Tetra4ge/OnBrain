# OnBrain Environment Variables Configuration

# General Application Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development

# Database Configuration (Docker network default hostnames used)
# Inside the docker containers, services will connect via container hostnames.
# For local client access, use localhost with corresponding exposed ports.
MONGO_URI=mongodb://root:rootpassword@mongo:27017/onbrain?authSource=admin
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=strongpassword

# ChromaDB Client Configuration
CHROMA_HOST=chroma
CHROMA_PORT=8000

# LLM & Reasoning API Keys
# Get Groq key: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# Get Gemini key: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: enable external LLM calls. Defaults keep ingestion and grounded Q&A local/reliable.
USE_LLM_EXTRACTION=false
USE_GENERATIVE_COPILOT=false

# Firebase Authentication Configuration
# Create project at: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_firebase_project_id_here
# Absolute file path to service account credential JSON inside container
FIREBASE_SERVICE_ACCOUNT_PATH=/app/service-account.json

# Frontend Firebase web configuration (copy these to frontend/.env)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_web_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
