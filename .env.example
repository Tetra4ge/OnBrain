# OnBrain Environment Variables Configuration

# General Application Configuration
PORT=8000
HOST=0.0.0.0

# Database Configuration (Docker network default hostnames used)
# Inside the docker containers, services will connect via container hostnames.
# For local client access, use localhost with corresponding exposed ports.
MONGO_URI=mongodb://mongo:27017/onbrain
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ChromaDB Client Configuration
CHROMA_HOST=chroma
CHROMA_PORT=8000

# LLM & Reasoning API Keys
# Get Groq key: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# Get Gemini key: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Authentication Configuration
# Create project at: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_firebase_project_id_here
# Local file path to service account credential JSON for backend admin verification
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
